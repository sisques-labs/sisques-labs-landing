---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { services, localizeService } from "../data/services";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = services.map((s) => localizeService(s, lang));
---

<section class="section services" id="services">
  <div class="container">
    <header class="services__head">
      <p class="eyebrow" data-reveal>{t("services.tag")}</p>
      <h2 class="section-title" data-reveal data-reveal-delay="60ms">
        {t("services.title")}
      </h2>
      <p class="lead" data-reveal data-reveal-delay="120ms">
        {t("services.lead")}
      </p>
    </header>

    <ul class="services__list">
      {
        items.map((s, i) => (
          <li class="srv" data-reveal data-reveal-delay={`${i * 60}ms`}>
            <span class="srv__num">{s.num}</span>
            <div class="srv__main">
              <h3 class="srv__title">{s.title}</h3>
              <p class="srv__desc">{s.description}</p>
            </div>
            <ul class="srv__items">
              {s.items.map((it) => (
                <li>
                  <span class="tick" aria-hidden="true">
                    ↳
                  </span>
                  {it}
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>

    <div class="services__cta" data-reveal>
      <a class="btn btn--primary" href="#contact">
        {t("services.cta")}
        <span class="arrow">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--bg-sunken);
    border-block: 1px solid var(--line);
  }
  .services__head {
    max-width: 60ch;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .services__head .section-title {
    margin-block: 1rem 1.4rem;
  }

  .services__list {
    list-style: none;
  }
  .srv {
    display: grid;
    grid-template-columns: 5rem 1.4fr 1fr;
    gap: 2rem;
    align-items: start;
    padding-block: clamp(1.6rem, 3vw, 2.4rem);
    border-top: 1px solid var(--line);
    transition: background-color 0.3s ease;
  }
  .srv:last-child {
    border-bottom: 1px solid var(--line);
  }
  .srv:hover {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }

  .srv__num {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink-faint);
    padding-top: 0.5rem;
  }
  .srv__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.2rem + 1.6vw, 2.3rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .srv__desc {
    margin-top: 0.7rem;
    color: var(--ink-soft);
    max-width: 42ch;
  }

  .srv__items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding-top: 0.4rem;
  }
  .srv__items li {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--ink-soft);
  }
  .tick {
    color: var(--accent-ink);
    background: var(--accent);
    width: 1.4em;
    height: 1.4em;
    display: inline-grid;
    place-items: center;
    border-radius: 5px;
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  .services__cta {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  @media (max-width: 860px) {
    .srv {
      grid-template-columns: 3rem 1fr;
      gap: 1rem 1.5rem;
    }
    .srv__items {
      grid-column: 2;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 1.2rem;
    }
  }
  @media (max-width: 520px) {
    .srv {
      grid-template-columns: 2.4rem 1fr;
    }
  }
</style>
