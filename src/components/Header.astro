---
import { getLangFromUrl, useTranslations, localizePath } from "../i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";
import LangToggle from "./LangToggle.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = localizePath("/", lang);

const links = [
  { href: "#work", label: t("nav.work") },
  { href: "#services", label: t("nav.services") },
  { href: "#contact", label: t("nav.contact") },
];
---

<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a class="brand" href={base} aria-label="Sisques Labs">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__name">sisques<span class="brand__labs">labs</span></span>
    </a>

    <nav class="nav" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="actions">
      <LangToggle />
      <ThemeToggle />
      <a class="btn btn--primary nav-cta" href="#contact">{t("nav.cta")}</a>
    </div>

    <button class="burger" id="burger" type="button" aria-label="Menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile">
      {links.map((l) => <a href={l.href} class="mobile-link">{l.label}</a>)}
    </nav>
    <a class="btn btn--primary" href="#contact">{t("nav.cta")}</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }
  .site-header.is-scrolled {
    border-color: var(--line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }
  .brand__mark {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 22%, transparent);
    animation: pulse 3.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 22%, transparent); }
    50% { box-shadow: 0 0 0 7px color-mix(in srgb, var(--accent) 8%, transparent); }
  }
  .brand__labs {
    color: var(--ink-faint);
    margin-left: 0.12em;
  }

  .nav {
    display: flex;
    gap: 2rem;
    margin-left: auto;
    margin-right: auto;
    font-size: 0.95rem;
  }
  .nav a {
    position: relative;
    color: var(--ink-soft);
    transition: color 0.2s ease;
  }
  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 100%;
    height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav a:hover {
    color: var(--ink);
  }
  .nav a:hover::after {
    transform: scaleX(1);
  }

  .actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .nav-cta {
    --pad-y: 0.6rem;
    padding-inline: 1.2rem;
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line-strong);
    border-radius: 100px;
  }
  .burger span {
    width: 18px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  .burger[aria-expanded="true"] span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }
  .burger[aria-expanded="true"] span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  .mobile-menu {
    padding: 1rem var(--gutter) 2rem;
    border-bottom: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mobile-menu nav {
    display: flex;
    flex-direction: column;
  }
  .mobile-link {
    padding: 0.85rem 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    border-bottom: 1px solid var(--line);
  }

  @media (max-width: 920px) {
    .nav,
    .nav-cta {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
  @media (min-width: 921px) {
    .mobile-menu {
      display: none !important;
    }
  }
</style>

<script>
  // Scrolled state
  const header = document.getElementById("site-header");
  const onScroll = () =>
    header?.classList.toggle("is-scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // Mobile menu
  const burger = document.getElementById("burger");
  const menu = document.getElementById("mobile-menu");
  burger?.addEventListener("click", () => {
    const open = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!open));
    if (menu) menu.hidden = open;
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      burger?.setAttribute("aria-expanded", "false");
      if (menu) menu.hidden = true;
    })
  );
</script>
