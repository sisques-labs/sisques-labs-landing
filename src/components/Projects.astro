---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { projects, localizeProject } from "../data/projects";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const items = projects.map((p) => localizeProject(p, lang));
---

<section class="section work" id="work">
  <div class="container">
    <header class="work__head">
      <div>
        <p class="eyebrow" data-reveal>{t("work.tag")}</p>
        <h2 class="section-title" data-reveal data-reveal-delay="60ms">
          {t("work.title")}
        </h2>
      </div>
      <p class="lead" data-reveal data-reveal-delay="120ms">{t("work.lead")}</p>
    </header>

    <ul class="work__grid">
      {
        items.map((p, i) => (
          <li
            class="card"
            data-reveal
            data-reveal-delay={`${(i % 2) * 80}ms`}
            style={`--card-accent:${p.accent}`}
          >
            <a
              class="card__link"
              href={p.url}
              target={p.url.startsWith("http") ? "_blank" : undefined}
              rel={p.url.startsWith("http") ? "noopener noreferrer" : undefined}
            >
              <div class="card__top">
                <span class="card__cat">{p.category}</span>
                <span class="card__year">{p.year}</span>
              </div>

              <div class="card__visual" aria-hidden="true">
                <span class="card__mark">{p.name.charAt(0)}</span>
                <div class="card__rings" />
              </div>

              <div class="card__body">
                <h3 class="card__name">{p.name}</h3>
                <p class="card__summary">{p.summary}</p>
              </div>

              <ul class="card__tags">
                {p.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>

              <div class="card__foot">
                <span class="card__role">
                  {t("work.role")}: {p.role}
                </span>
                <span class="card__cta">
                  {t("work.visit")} <span class="arrow">→</span>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .work__head {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2rem;
    align-items: end;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .work__head .section-title {
    margin-top: 1rem;
  }
  .work__head .lead {
    padding-bottom: 0.4rem;
  }

  .work__grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.1rem, 2vw, 1.8rem);
  }

  .card {
    position: relative;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--card);
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .card:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--card-accent) 60%, var(--line));
    box-shadow: var(--shadow);
  }
  .card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: clamp(1.4rem, 3vw, 2rem);
    gap: 1.25rem;
  }

  .card__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .card__cat {
    color: var(--ink-soft);
  }

  .card__visual {
    position: relative;
    height: clamp(120px, 16vw, 180px);
    border-radius: var(--radius);
    background: radial-gradient(
        120% 120% at 50% 0%,
        color-mix(in srgb, var(--card-accent) 22%, transparent),
        transparent 70%
      ),
      var(--bg-sunken);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .card__mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    color: var(--card-accent);
    line-height: 1;
    z-index: 1;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card:hover .card__mark {
    transform: scale(1.08) rotate(-3deg);
  }
  .card__rings {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle at 50% 50%,
      transparent 28%,
      color-mix(in srgb, var(--card-accent) 18%, transparent) 28.5%,
      transparent 29.5%,
      transparent 44%,
      color-mix(in srgb, var(--card-accent) 12%, transparent) 44.5%,
      transparent 45.5%
    );
    opacity: 0.7;
  }

  .card__name {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1.2rem + 1vw, 1.9rem);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .card__summary {
    margin-top: 0.5rem;
    color: var(--ink-soft);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
  }
  .card__tags li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--line);
    border-radius: 100px;
    color: var(--ink-soft);
  }

  .card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .card__role {
    color: var(--ink-faint);
  }
  .card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink);
    font-weight: 500;
  }
  .card:hover .card__cta .arrow {
    transform: translateX(4px);
  }
  .card__cta .arrow {
    transition: transform 0.2s ease;
  }

  @media (max-width: 860px) {
    .work__head {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 1.2rem;
    }
  }
  @media (max-width: 640px) {
    .work__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
