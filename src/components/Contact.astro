---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const email = "hola@sisques-labs.com";
const budgets =
  lang === "es"
    ? [t("contact.budget.none"), "< 5k €", "5k – 15k €", "15k – 40k €", "> 40k €"]
    : [t("contact.budget.none"), "< $5k", "$5k – $15k", "$15k – $40k", "> $40k"];
---

<section class="section contact" id="contact">
  <div class="container contact__inner">
    <div class="contact__intro">
      <p class="eyebrow" data-reveal>{t("contact.tag")}</p>
      <h2 class="contact__title display" data-reveal data-reveal-delay="60ms">
        {t("contact.title")}
      </h2>
      <p class="lead" data-reveal data-reveal-delay="120ms">
        {t("contact.lead")}
      </p>
      <p class="contact__email" data-reveal data-reveal-delay="180ms">
        {t("contact.or")}<br />
        <a href={`mailto:${email}`}>{email}</a>
      </p>
    </div>

    <form class="contact__form" id="contact-form" data-reveal data-reveal-delay="120ms">
      <div class="field">
        <label for="name">{t("contact.name")}</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          placeholder={t("contact.placeholder.name")}
        />
      </div>

      <div class="field">
        <label for="email">{t("contact.email")}</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder={t("contact.placeholder.email")}
        />
      </div>

      <div class="field">
        <label for="budget">{t("contact.budget")}</label>
        <div class="select-wrap">
          <select id="budget" name="budget">
            {budgets.map((b) => <option value={b}>{b}</option>)}
          </select>
          <span class="select-caret" aria-hidden="true">▾</span>
        </div>
      </div>

      <div class="field">
        <label for="message">{t("contact.message")}</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          placeholder={t("contact.placeholder.message")}></textarea>
      </div>

      <button class="btn btn--primary contact__submit" type="submit">
        {t("contact.send")}
        <span class="arrow">→</span>
      </button>
    </form>
  </div>
</section>

<style>
  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }
  .contact__title {
    font-size: clamp(2.4rem, 1.6rem + 4vw, 4.5rem);
    margin-block: 1.2rem 1.5rem;
  }
  .contact__email {
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--ink-faint);
    line-height: 1.9;
  }
  .contact__email a {
    color: var(--ink);
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 1px;
  }
  .contact__email a:hover {
    background: var(--accent);
    color: var(--accent-ink);
  }

  .contact__form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.3rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 4vw, 2.4rem);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field:nth-child(3),
  .field:nth-child(4),
  .contact__submit {
    grid-column: 1 / -1;
  }
  label {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  input,
  textarea,
  select {
    width: 100%;
    font: inherit;
    font-size: 0.95rem;
    color: var(--ink);
    background: var(--bg-sunken);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.8rem 0.95rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  textarea {
    resize: vertical;
    min-height: 110px;
  }
  input::placeholder,
  textarea::placeholder {
    color: var(--ink-faint);
  }
  input:focus,
  textarea:focus,
  select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .select-wrap {
    position: relative;
  }
  select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
  }
  .select-caret {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--ink-faint);
    font-size: 0.8rem;
  }
  .contact__submit {
    margin-top: 0.3rem;
    width: 100%;
  }

  @media (max-width: 860px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 460px) {
    .contact__form {
      grid-template-columns: 1fr;
    }
    .field:nth-child(1),
    .field:nth-child(2) {
      grid-column: 1 / -1;
    }
  }
</style>

<script>
  // No backend yet: compose a prefilled email so the form is functional.
  // Swap this for Formspree / an API endpoint when ready.
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = String(data.get("name") || "");
    const email = String(data.get("email") || "");
    const budget = String(data.get("budget") || "");
    const message = String(data.get("message") || "");
    const subject = encodeURIComponent(`Nuevo proyecto — ${name}`);
    const body = encodeURIComponent(
      `Nombre: ${name}\nEmail: ${email}\nPresupuesto: ${budget}\n\n${message}`
    );
    window.location.href = `mailto:hola@sisques-labs.com?subject=${subject}&body=${body}`;
  });
</script>
